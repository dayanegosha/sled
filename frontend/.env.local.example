# Скопируйте в .env.local на сервере и при сборке (npm run build).
# NEXT_PUBLIC_* подставляются в бандл на этапе сборки — без ключа карта не загрузится.

NEXT_PUBLIC_API_URL=https://ваш-домен/api/v1
NEXT_PUBLIC_WS_URL=https://ваш-домен
NEXT_PUBLIC_VK_APP_ID=
NEXT_PUBLIC_VK_REDIRECT_URL=https://ваш-домен/api/v1/auth/vk/callback
NEXT_PUBLIC_VK_MAPS_API_KEY=
